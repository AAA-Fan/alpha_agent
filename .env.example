OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Optional runtime flags
VERBOSE=false
STORAGE_ENABLED=true
STORAGE_URL=sqlite:///data/agent_store.db
STORAGE_USER_ID=
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.3
API_ALLOWED_ORIGINS=*
API_BASE_URL=http://localhost:8000
DASHBOARD_USE_API=true

# Pair ledger and monitor tuning
PAIR_UNIVERSE_PATH=data/sp500_top100.json
PAIR_LEDGER_PATH=data/pairs_ledger.json
PAIR_LOOKBACK_DAYS=90
PAIR_TOP_K=5
PAIR_MIN_CORR=0.85
PAIR_REBUILD=false
PAIR_REFRESH_INTERVAL_HOURS=
PAIR_REFRESH_UTC_HOUR=21
PAIR_REFRESH_UTC_MINUTE=0
PAIR_ADD=
PAIR_REMOVE=
PAIR_MONITOR_WINDOW=5
PAIR_MONITOR_INTERVAL=daily
PAIR_ZSCORE_WINDOW=20
PAIR_ZSCORE_THRESHOLD=1.5
PAIR_DIVERGENCE_THRESHOLD=1.5

# Alpha Vantage request controls
ALPHAVANTAGE_RATE_LIMIT_PER_MIN=75
ALPHAVANTAGE_INTRADAY_TTL=300

# Forecast/risk/backtest controls
FEATURE_LOOKBACK_DAYS=220
FORECAST_MODEL_PATH=data/forecast_model.json
FORECAST_HORIZON_DAYS=5
FORECAST_BUY_THRESHOLD=0.55
FORECAST_SELL_THRESHOLD=0.45

# V2 Cross-Sectional Model (Phase 3)
FORECAST_MODEL_VERSION=v1
# FORECAST_MODEL_VERSION=v2
TRAIN_TICKERS_SOURCE=sp500_top100
TRAIN_TICKERS_PATH=data/sp500_top100.json
FORECAST_LGB_MODEL_PATH=data/forecast_model.lgb
FORECAST_LGB_META_PATH=data/forecast_model_meta.json
FORECAST_CALIBRATOR_PATH=data/forecast_calibrator.pkl
# V2 paths (uncomment when using v2):
# FORECAST_LGB_MODEL_PATH=data/forecast_model_v2.lgb
# FORECAST_LGB_META_PATH=data/forecast_model_v2_meta.json
# FORECAST_CALIBRATOR_PATH=data/forecast_calibrator_v2.pkl
CS_CACHE_DIR=data/cross_section_cache
CS_CACHE_TTL_HOURS=24

REGIME_HIGH_VOL_THRESHOLD=0.35
REGIME_LOW_VOL_THRESHOLD=0.16
RISK_TARGET_ANNUAL_VOL=0.12
RISK_MAX_POSITION_SIZE=1.0
RISK_REWARD_RATIO=2.0
BACKTEST_LOOKBACK_DAYS=320
BACKTEST_HORIZON_DAYS=5
BACKTEST_TRANSACTION_COST_BPS=5
